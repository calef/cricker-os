#!/bin/sh
# script/lint: run clippy across the workspace with warnings denied (the CI clippy gate).
#
# Two invocations, because the workspace has two worlds: the pure-logic host crates and xtask
# build for the host (lint their tests too), while kernel and user are bare-metal no_std and only
# build for the aarch64 target, where --all-targets would need a libtest that does not exist. Not
# one of the canonical scripts, but it keeps the CI job a one-liner. See notes/scripts.md.

set -e
cd "$(dirname "$0")/.."

echo "==> clippy: host crates + xtask"
cargo clippy --workspace --exclude kernel --exclude user --all-targets -- -D warnings

echo "==> clippy: kernel + user (aarch64)"
cargo clippy -p kernel -p user --target aarch64-unknown-none-softfloat -- -D warnings
